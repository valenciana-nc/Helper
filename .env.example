# Copy to .env and fill in. Do not commit .env.

# Optional. Only needed for voice features (mic transcription + spoken replies).
# Chat and computer-use are powered by your ChatGPT/Codex subscription via the
# "Sign in with ChatGPT" button in the dashboard — no API key required for those.
OPENAI_API_KEY=

# Provider selection. One of: codex, openai_compat, anthropic, gemini.
#   codex          — sign in with ChatGPT (default, no API key needed for chat)
#   openai_compat  — any OpenAI-compatible /v1/chat/completions endpoint
#   anthropic      — Anthropic Claude (needs HELPER_ANTHROPIC_API_KEY)
#   gemini         — Google Gemini (needs HELPER_GEMINI_API_KEY)
HELPER_PROVIDER=codex

# Per-provider API keys. Only the key for the active provider is used.
HELPER_ANTHROPIC_API_KEY=
HELPER_GEMINI_API_KEY=

# Optional. OpenAI-compatible endpoint config (used when HELPER_PROVIDER=openai_compat,
# or as the legacy fallback when both base URL + key are set).
HELPER_API_BASE_URL=
HELPER_API_KEY=
HELPER_API_MODEL=

HELPER_HOTKEY=ctrl+shift+space
HELPER_DEFAULT_MODE=help

# Agent / vision / computer use
HELPER_AGENT_MODEL=gpt-5.5
HELPER_REASONING_MODEL=gpt-5.5
HELPER_SPEAK_TYPED_CHAT=false

# Generation parameters (sent to providers that accept them — codex ignores).
HELPER_TEMPERATURE=0.7
HELPER_MAX_TOKENS=4096

# Use an LLM to disambiguate "is this a chat or a computer-use request?" turns.
HELPER_ROUTE_CLASSIFIER=true

# UI appearance — light or dark.
HELPER_THEME=light

# Audio (requires OPENAI_API_KEY)
HELPER_STT_MODEL=whisper-1
HELPER_TTS_MODEL=gpt-4o-mini-tts
HELPER_TTS_VOICE=alloy
HELPER_AUDIO_SAMPLE_RATE=16000
HELPER_AUDIO_CHANNELS=1
HELPER_AUDIO_BLOCKSIZE=0
HELPER_AUDIO_SILENCE_THRESHOLD=700
HELPER_AUDIO_MIN_SECONDS=0.25
HELPER_AUDIO_TRIM_PAD_MS=150

HELPER_MAX_AGENT_STEPS=25
HELPER_AGENT_TIMEOUT_SEC=180
HELPER_SCREENSHOT_MAX_EDGE=1280
HELPER_HISTORY_MAX_TURNS=12
HELPER_HISTORY_MAX_TOKENS=12000
